{
  "name": "axtolab-ai-connector-free-mcpb",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "description": "MCP server for Axtolab AI Connector for WordPress — safely manage WordPress content from Claude, ChatGPT, and MCP-compatible AI clients.",
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/guides/**/*.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && printf '#!/usr/bin/env node\\n' | cat - dist/index.js > dist/index.tmp.js && mv dist/index.tmp.js dist/index.js && rm -rf dist/guides && cp -r src/guides dist/guides",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test",
    "build:mcpb": "npm run build && node esbuild.mcpb.mjs"
  },
  "keywords": [
    "mcp",
    "wordpress",
    "claude",
    "ai",
    "content-management",
    "editorial",
    "model-context-protocol"
  ],
  "license": "GPL-2.0-or-later",
  "author": "Axtolab",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "markdown-it": "^14.1.1",
    "zod": "~3.23.8"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.5",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
